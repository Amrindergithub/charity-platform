    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "truffle": "^5.11.5"
  }
}
