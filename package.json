{
  "name": "charity-platform",
  "version": "2.0.0",
  "description": "TrustChain - Decentralised Charity Platform with DAO Governance",
  "main": "backend/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node backend/index.js",
    "dev": "nodemon backend/index.js",
    "compile": "truffle compile",
